{
  "method": "GET",
  "path": "/api/admin/users",
  "name": "List users",
  "description": "Returns a paginated list of users for an administrative console.",
  "parameters": [
    {
      "name": "page",
      "in": "query",
      "required": false,
      "description": "Page number starting from 1.",
      "schema": {
        "type": "integer",
        "minimum": 1,
        "default": 1
      }
    },
    {
      "name": "pageSize",
      "in": "query",
      "required": false,
      "description": "Number of users to return per page.",
      "schema": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100,
        "default": 20
      }
    },
    {
      "name": "status",
      "in": "query",
      "required": false,
      "description": "Optional user status filter.",
      "schema": {
        "type": "string",
        "enum": ["active", "disabled"]
      }
    }
  ],
  "responses": {
    "200": {
      "description": "Users returned successfully.",
      "content": {
        "application/json": {
          "example": {
            "items": [
              {
                "id": "user_001",
                "name": "Alex Example",
                "status": "active"
              }
            ],
            "page": 1,
            "pageSize": 20,
            "total": 1
          }
        }
      }
    }
  }
}
